# ============================================================
# HireFlow AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file. It is already in .gitignore.
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Web Search (for company intel, resource discovery) ---
TAVILY_API_KEY=your_tavily_api_key_here
# SERPAPI_API_KEY=your_serpapi_key_here   # alternative

# --- Email Delivery ---
SENDGRID_API_KEY=your_sendgrid_api_key_here
# RESEND_API_KEY=your_resend_api_key_here  # alternative
FROM_EMAIL=hireflow@yourdomain.com

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/hireflow

# --- File Storage ---
# Set to 'local' during development, 's3' in production
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# --- Application Config ---
APP_ENV=development        # development | production
DEBUG=true
SECRET_KEY=change_this_to_a_random_secret_string
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
